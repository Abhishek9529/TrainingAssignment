<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:mvc="http://www.springframework.org/schema/mvc"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"

       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       https://www.springframework.org/schema/beans/spring-beans.xsd

       http://www.springframework.org/schema/context
       https://www.springframework.org/schema/context/spring-context.xsd

       http://www.springframework.org/schema/mvc
       https://www.springframework.org/schema/mvc/spring-mvc.xsd">

    <!-- Scan Controllers -->
    <context:component-scan base-package="com.mednet.controller"/>

    <!-- Enable Spring MVC -->
    <mvc:annotation-driven/>

    <!-- Static Resources: Serve JS, CSS, images etc. directly from webapp folder.
         Without this, DispatcherServlet (mapped to /) intercepts all requests
         and returns 404 for static files. -->
    <mvc:resources mapping="/js/**" location="/js/"/>
    <mvc:resources mapping="/css/**" location="/css/"/>
    <mvc:resources mapping="/images/**" location="/images/"/>

    <!-- Multipart File Upload Configuration -->
    <!-- This bean enables Spring MVC to handle file uploads via MultipartFile parameter.
         It processes multipart/form-data requests and makes uploaded files available
         as MultipartFile objects in controller methods.
    -->
    <bean id="multipartResolver" class="org.springframework.web.multipart.commons.CommonsMultipartResolver">
        
        <!-- Maximum upload file size in bytes: 10 MB -->
        <!-- This prevents extremely large file uploads that could consume server resources.
             Users attempting to upload files larger than this limit will receive an error.
        -->
        <property name="maxUploadSize" value="10485760"/>
        
        <!-- Maximum request size in bytes: 10 MB -->
        <!-- Limits the total size of the entire multipart request.
        -->
        <property name="maxInMemorySize" value="10485760"/>
        
    </bean>

    <!-- JSP View Resolver -->
    <bean class="org.springframework.web.servlet.view.InternalResourceViewResolver">

        <property name="prefix" value="/jsp/"/>

        <property name="suffix" value=".jsp"/>

    </bean>

</beans>